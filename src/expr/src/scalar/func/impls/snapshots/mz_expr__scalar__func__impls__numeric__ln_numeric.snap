fn ln_numeric(a: Numeric) -> Result<Numeric, EvalError> {
    log_guard_numeric(&a, "ln")?;
    let mut cx = numeric::cx_datum();
    let mut result = ln_fast(&mut cx, &a);
    numeric::munge_numeric(&mut result).unwrap();
    Ok(result)
}
