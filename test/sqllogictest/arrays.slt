query error operator does not exist: integer\[\] <> text\[\]
SELECT ARRAY[1,2,3] != ARRAY['1','2','3']

query error operator does not exist: integer\[\] < text\[\]
SELECT ARRAY[1,2,3] < ARRAY['1','2','3']

query error operator does not exist: integer\[\] <= text\[\]
SELECT ARRAY[1,2,3] <= ARRAY['1','2','3']

query error operator does not exist: integer\[\] > text\[\]
SELECT ARRAY[1,2,3] > ARRAY['1','2','3']

query error operator does not exist: integer\[\] >= text\[\]
