12  1
11  0
10  1
9  0
8  0
7  0
6  0
5  0
4  1
3  0
2  0
1  1
0  0


query I
SELECT get_bit('\xF00a'::bytea, 13);
----
0

query I
SELECT get_bit('\xF00a'::bytea, 5);
----
1

query II
SELECT n, get_bit('\xF00a'::bytea, n) FROM generate_series(0, 15) as n ORDER BY n DESC;
----
15  0
14  0
13  0
12  0
11  1
10  0
9  1
