# Additional tests in test/sqllogictest/cockroach/with.slt

mode cockroach

statement ok
CREATE TABLE x (a int)

statement ok
INSERT INTO x VALUES (1), (2), (3)

statement ok
CREATE TABLE y (a int)

statement ok
INSERT INTO y VALUES (2), (3), (4)

# Check that a CTE on the lhs of a join works
query I
WITH t AS (SELECT * FROM y WHERE a < 3)
  SELECT * FROM t NATURAL JOIN x
----
2

# Using a CTE inside a correlated subquery
query I
WITH t(x) AS (SELECT * FROM y WHERE a < 3)
  SELECT * FROM x WHERE a IN (
    SELECT a FROM t WHERE x.a = t.x
  )
----
2

# Using a correlated subquery inside a CTE
query I
SELECT * FROM x WHERE a IN
  (WITH t AS (SELECT * FROM y WHERE y.a = x.a) SELECT * FROM t);
----
2
3

statement error more than one record produced in subquery
WITH c AS (SELECT a + 1 FROM x) SELECT (SELECT * FROM c);

# Allow re-using names laterally.
query I rowsort
SELECT * FROM (
  (WITH c AS (SELECT 1) SELECT * FROM c)
  UNION ALL
  (WITH c AS (SELECT 2) SELECT * FROM c)
)
----
1
2

statement error specified more than once
SELECT * FROM (
  (WITH c AS (SELECT 1), c AS (SELECT 2)
  SELECT * FROM c UNION ALL SELECT * FROM c)
)

# Allow re-using names nested.
query I rowsort
SELECT * FROM (
  (WITH c AS (SELECT 1) SELECT * FROM
    (WITH c AS (SELECT 2) SELECT * FROM c)
    UNION ALL
    SELECT * FROM c
  )
)
----
1
2

# CTE names should only be accessible in their scope.
statement error unknown catalog item
SELECT * FROM (
  (WITH c AS (SELECT 1) SELECT * FROM c)
    UNION ALL
  SELECT * FROM c
)

query I
WITH foo AS (SELECT 1)
  (SELECT * FROM foo
    UNION ALL
  (WITH foo AS (SELECT 2) SELECT * FROM foo)
    UNION ALL
  (SELECT * FROM foo))
----
1
1
2

# See 5766.
query error column "a2.f1" does not exist
SELECT * FROM (VALUES (true)) a2 (f1) WHERE (
    SELECT TRUE FROM (VALUES (true)) AS a2 (f2)
    WHERE (SELECT a2.f1)
)

statement ok
CREATE TABLE squares (x int, y int);

statement ok
CREATE TABLE roots (x int, y int);

statement ok
CREATE TABLE cubes (x int, y int);

statement ok
INSERT INTO squares VALUES
    (1, 1), (2, 4), (3, 9), (4, 16);

statement ok
INSERT INTO roots VALUES
    (1, 1), (4, 2), (9, 3), (16, 4);

statement ok
INSERT INTO cubes VALUES
    (1, 1), (2, 8), (3, 27), (4, 16);

# Correlated expression––this should only return values where squares.y is
# in roots.y and sqaures.x
query II
SELECT * FROM squares
WHERE x IN (
    SELECT y FROM roots
    WHERE y IN (
        SELECT squares.y
    )
);
----
1 1

# Correlated CTE
query II
SELECT * FROM squares
WHERE x IN (
    WITH squares_y AS (
        SELECT squares.y
    )
    SELECT y FROM roots
    WHERE y IN (
        SELECT y FROM squares_y
    )
);
----
1 1

# Same query, but inside a view. Regression test for database-issues#1582.
statement ok
CREATE MATERIALIZED VIEW v AS
SELECT * FROM squares
WHERE x IN (
    WITH squares_y AS (
        SELECT squares.y
    )
    SELECT y FROM roots
    WHERE y IN (
        SELECT y FROM squares_y
    )
);

query II
SELECT * FROM v
----
1 1

# Correlated CTE in different level than it was introduced. This is needlessly
# convoluted but caused crashes in early iterations of CTE's development.
query II
SELECT * FROM squares
WHERE x IN (
    WITH squares_x AS (
        SELECT squares.x
    )
    SELECT t0.x
    FROM (
        SELECT roots.x
        FROM roots
        JOIN (
            SELECT t2.x FROM (
                SELECT cubes.x FROM cubes
                JOIN squares_x
                ON squares_x.x = cubes.x
                WHERE cubes.x IN (SELECT x FROM squares_x)
            ) t2
        ) AS t1
        ON t1.x = roots.x
    ) AS t0
);
----
1 1
4 16

# Use same query at two levels. Obtusely check for quadratic powers.
query I rowsort
WITH squares_y AS (
    SELECT y FROM squares
  )
SELECT * FROM squares_y WHERE y IN (
  SELECT y * y FROM squares_y
)
----
1
16

# PostgreSQL tests
query TT
WITH q AS (SELECT 'foo' AS x)
SELECT x, pg_typeof(x)  FROM q;
----
foo text

query I rowsort
WITH outermost(x) AS (
  SELECT 1
  UNION (WITH innermost as (SELECT 2)
         SELECT * FROM innermost
         UNION SELECT 3)
)
SELECT * FROM outermost ORDER BY 1;
----
1
2
3

query error unknown catalog item 'outermost'
WITH outermost(x) AS (
  SELECT 1
  UNION (WITH innermost as (SELECT 2)
         SELECT * FROM outermost  -- fail
         UNION SELECT * FROM innermost)
)
SELECT * FROM outermost ORDER BY 1;

# test database-issues#7102
query I colnames
WITH count AS (VALUES (9)) SELECT count(*) FROM count;
----
count
1

# ==========================================
# Additional edge case tests for potential panics/internal errors
# ==========================================

### Basic CTE edge cases ###

query I
WITH cte AS (SELECT 1 AS x) SELECT * FROM cte
----
1

query I
WITH cte AS (SELECT NULL::int AS x) SELECT * FROM cte
----
NULL

query II
WITH cte AS (SELECT 1 AS a, 2 AS b) SELECT a, b FROM cte
----
1  2

### Multiple CTEs edge cases ###

query II
WITH
    cte1 AS (SELECT 1 AS x),
    cte2 AS (SELECT 2 AS y)
SELECT * FROM cte1, cte2
----
1  2

query I
WITH
    cte1 AS (SELECT 1 AS x),
    cte2 AS (SELECT x + 1 AS y FROM cte1)
SELECT y FROM cte2
----
2

query I
WITH
    cte1 AS (SELECT 1 AS x),
    cte2 AS (SELECT x + 1 AS y FROM cte1),
    cte3 AS (SELECT y + 1 AS z FROM cte2)
SELECT z FROM cte3
----
3

### CTE referenced multiple times ###

query II
WITH cte AS (SELECT 1 AS x)
SELECT a.x, b.x FROM cte a, cte b
----
1  1

query I
WITH cte AS (SELECT 1 AS x)
SELECT (SELECT x FROM cte) + (SELECT x FROM cte)
----
2

### CTE with subquery edge cases ###

query I
WITH cte AS (SELECT * FROM (SELECT 1 AS x) sub)
SELECT * FROM cte
----
1

query I
WITH cte AS (SELECT 1 AS x)
SELECT * FROM (SELECT * FROM cte) sub
----
1

### CTE with UNION edge cases ###

query I
WITH cte AS (SELECT 1 AS x UNION SELECT 2)
SELECT * FROM cte ORDER BY x
----
1
2

query I
WITH cte AS (SELECT 1 AS x UNION ALL SELECT 1)
SELECT * FROM cte ORDER BY x
----
1
1

### CTE with JOIN edge cases ###

statement ok
CREATE TABLE cte_test1 (id int, val text)

statement ok
CREATE TABLE cte_test2 (id int, val text)

statement ok
INSERT INTO cte_test1 VALUES (1, 'a'), (2, 'b'), (3, 'c')

statement ok
INSERT INTO cte_test2 VALUES (2, 'x'), (3, 'y'), (4, 'z')

query ITT
WITH cte AS (SELECT * FROM cte_test1)
SELECT cte.id, cte.val, t2.val
FROM cte
JOIN cte_test2 t2 ON cte.id = t2.id
ORDER BY cte.id
----
2  b  x
3  c  y

### CTE with aggregates edge cases ###

query IR
WITH cte AS (SELECT id, val FROM cte_test1)
SELECT COUNT(*), AVG(id) FROM cte
----
3  2

query TI
WITH cte AS (SELECT val, COUNT(*) as cnt FROM cte_test1 GROUP BY val)
SELECT * FROM cte ORDER BY val
----
a  1
b  1
c  1

### CTE with ORDER BY and LIMIT edge cases ###

query I
WITH cte AS (SELECT id FROM cte_test1 ORDER BY id DESC)
SELECT * FROM cte ORDER BY id
----
1
2
3

query I
WITH cte AS (SELECT id FROM cte_test1)
SELECT * FROM cte ORDER BY id LIMIT 2
----
1
2

query I
WITH cte AS (SELECT id FROM cte_test1 ORDER BY id)
SELECT * FROM cte LIMIT 1
----
1

### CTE with NULL handling edge cases ###

statement ok
INSERT INTO cte_test1 VALUES (NULL, NULL)

query II
WITH cte AS (SELECT id, id * 2 as doubled FROM cte_test1)
SELECT * FROM cte WHERE id IS NOT NULL ORDER BY id
----
1  2
2  4
3  6

query II
WITH cte AS (SELECT id, id * 2 as doubled FROM cte_test1)
SELECT * FROM cte WHERE id IS NULL
----
NULL  NULL

### CTE with DISTINCT edge cases ###

statement ok
INSERT INTO cte_test1 VALUES (1, 'a')

query I
WITH cte AS (SELECT DISTINCT id FROM cte_test1)
SELECT * FROM cte WHERE id IS NOT NULL ORDER BY id
----
1
2
3

### CTE shadowing edge cases ###

query I
WITH cte AS (SELECT 1 AS x)
SELECT * FROM (
    WITH cte AS (SELECT 2 AS x)
    SELECT * FROM cte
)
----
2

### CTE with empty result edge cases ###

query I
WITH cte AS (SELECT id FROM cte_test1 WHERE false)
SELECT * FROM cte
----

query I
WITH cte AS (SELECT id FROM cte_test1 WHERE false)
SELECT COUNT(*) FROM cte
----
0

### CTE with complex expressions ###

query I
WITH cte AS (
    SELECT
        CASE WHEN id > 2 THEN id * 2 ELSE id END as computed
    FROM cte_test1
    WHERE id IS NOT NULL
)
SELECT * FROM cte ORDER BY computed
----
1
2
6

### CTE with column aliases ###

query II
WITH cte(col1, col2) AS (SELECT 1, 2)
SELECT col1, col2 FROM cte
----
1  2

query II
WITH cte(a, b) AS (SELECT id, val FROM cte_test1 WHERE id = 1)
SELECT a, b FROM cte
----
1  a

### Nested CTE edge cases ###

query I
WITH outer_cte AS (
    WITH inner_cte AS (SELECT 1 AS x)
    SELECT x + 1 AS y FROM inner_cte
)
SELECT y FROM outer_cte
----
2

### CTE with EXISTS edge cases ###

query B
WITH cte AS (SELECT 1 AS x)
SELECT EXISTS (SELECT 1 FROM cte)
----
true

query B
WITH cte AS (SELECT 1 AS x WHERE false)
SELECT EXISTS (SELECT 1 FROM cte)
----
false

### CTE with IN edge cases ###

query I
WITH cte AS (SELECT 1 AS x UNION SELECT 2 UNION SELECT 3)
SELECT id FROM cte_test1 WHERE id IN (SELECT x FROM cte) ORDER BY id
----
1
2
3

### Cleanup ###

statement ok
DROP TABLE cte_test1

statement ok
DROP TABLE cte_test2
