### Boolean with aggregate functions ###

statement ok
CREATE TABLE bool_test (val bool)

statement ok
INSERT INTO bool_test VALUES (true), (true), (false), (NULL)

query B
SELECT bool_and(val) FROM bool_test
----
false

query B
SELECT bool_or(val) FROM bool_test
----
true

query I
SELECT COUNT(*) FROM bool_test WHERE val
----
2

query I
SELECT COUNT(*) FROM bool_test WHERE NOT val
----
1

query I
SELECT COUNT(*) FROM bool_test WHERE val IS NULL
----
1

statement ok
DROP TABLE bool_test

### Boolean ORDER BY edge cases ###

statement ok
CREATE TABLE bool_order_test (val bool)

statement ok
INSERT INTO bool_order_test VALUES (true), (false), (NULL), (true), (false)

query B
SELECT val FROM bool_order_test ORDER BY val
----
false
false
true
true
NULL

query B
SELECT val FROM bool_order_test ORDER BY val DESC
----
NULL
true
true
false
false

query B
SELECT val FROM bool_order_test ORDER BY val NULLS FIRST
----
NULL
false
false
true
true

statement ok
DROP TABLE bool_order_test
