statement ok
CREATE TABLE limit_test (x int)

statement ok
INSERT INTO limit_test VALUES (1), (2), (3), (4), (5)

query I
SELECT x FROM limit_test ORDER BY x LIMIT 0
----

query I
SELECT x FROM limit_test ORDER BY x LIMIT 100
----
1
2
3
4
5

query I
SELECT x FROM limit_test ORDER BY x OFFSET 0
----
1
2
3
4
5

query I
SELECT x FROM limit_test ORDER BY x OFFSET 100
----

query I
SELECT x FROM limit_test ORDER BY x LIMIT 2 OFFSET 2
----
3
4

query I
SELECT x FROM limit_test ORDER BY x LIMIT 2 OFFSET 10
----

statement ok
DROP TABLE limit_test

# ==========================================
# UNION/INTERSECT/EXCEPT edge cases
# ==========================================

### UNION edge cases ###

query I rowsort
SELECT 1 UNION SELECT 1
----
1

query I rowsort
SELECT 1 UNION ALL SELECT 1
----
1
1

query I rowsort
SELECT 1 WHERE false UNION SELECT 2
----
2

query I rowsort
SELECT 1 UNION SELECT 2 WHERE false
----
1

query I rowsort
SELECT 1 WHERE false UNION SELECT 2 WHERE false
----

### INTERSECT edge cases ###

query I
SELECT 1 INTERSECT SELECT 1
----
1

query I
SELECT 1 INTERSECT SELECT 2
----

query I
SELECT 1 WHERE false INTERSECT SELECT 1
----

### EXCEPT edge cases ###

query I
SELECT 1 EXCEPT SELECT 2
----
1

query I
SELECT 1 EXCEPT SELECT 1
----

query I
SELECT 1 WHERE false EXCEPT SELECT 1
----

# ==========================================
# JOIN edge cases
# ==========================================

statement ok
CREATE TABLE join_left (x int)

statement ok
CREATE TABLE join_right (y int)

statement ok
INSERT INTO join_left VALUES (1), (2), (NULL)

statement ok
INSERT INTO join_right VALUES (2), (3), (NULL)

### INNER JOIN with NULLs ###

query II rowsort
SELECT * FROM join_left INNER JOIN join_right ON x = y
----
2  2

### LEFT JOIN with NULLs ###

query II rowsort
SELECT * FROM join_left LEFT JOIN join_right ON x = y
----
1  NULL
2  2
NULL  NULL

### RIGHT JOIN with NULLs ###

query II rowsort
SELECT * FROM join_left RIGHT JOIN join_right ON x = y
----
2  2
NULL  3
NULL  NULL

### FULL OUTER JOIN with NULLs ###

query II rowsort
SELECT * FROM join_left FULL OUTER JOIN join_right ON x = y
----
1  NULL
2  2
NULL  3
NULL  NULL
NULL  NULL

### CROSS JOIN with empty table ###

query II rowsort
SELECT * FROM join_left CROSS JOIN join_right WHERE false
----

### Join on NULL = NULL ###

query II rowsort
SELECT * FROM join_left INNER JOIN join_right ON x IS NOT DISTINCT FROM y
----
2  2
NULL  NULL

statement ok
DROP TABLE join_left

statement ok
DROP TABLE join_right

