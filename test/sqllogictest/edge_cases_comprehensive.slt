# Comprehensive edge case tests designed to catch potential panics,
# internal errors, and unexpected behavior in the Materialize database.

mode cockroach

# ==========================================
# String function edge cases
# ==========================================

### substr/substring edge cases ###

query T
SELECT substr('hello', 0)
----
hello

query T
SELECT substr('hello', -10)
----
hello

query T
SELECT substr('hello', 100)
----
(empty)

query T
SELECT substr('hello', 1, 0)
----
(empty)

query T
SELECT substr('hello', 1, -1)
----
(empty)

query T
SELECT substr('hello', 1, 100)
----
hello

query T
SELECT substr('', 1)
----
(empty)

query T
SELECT substr('', 1, 10)
----
(empty)

query T
SELECT substr(NULL, 1)
----
NULL

query T
SELECT substr('hello', NULL)
----
NULL

query T
SELECT substr('hello', 1, NULL)
----
NULL

# Very large start position
query T
SELECT substr('hello', 2147483647)
----
(empty)

# Negative length (should be treated as 0 or error)
query T
SELECT substr('hello', 1, -2147483648)
----
(empty)

### length function edge cases ###

query I
SELECT length('')
----
0

query I
SELECT length(NULL)
----
NULL

query I
SELECT length(repeat('a', 10000))
----
10000

### repeat function edge cases ###

query T
SELECT repeat('', 100)
----
(empty)

query T
SELECT repeat('a', 0)
----
(empty)

query T
SELECT repeat('a', -1)
----
(empty)

query T
SELECT repeat(NULL, 5)
----
NULL

query T
SELECT repeat('a', NULL)
----
NULL

### left/right function edge cases ###

query T
SELECT left('hello', 0)
----
(empty)

query T
SELECT left('hello', -1)
----
hell

query T
SELECT left('hello', 100)
----
hello

query T
SELECT left('', 5)
----
(empty)

query T
SELECT right('hello', 0)
----
(empty)

query T
SELECT right('hello', -1)
----
ello

query T
SELECT right('hello', 100)
----
hello

### lpad/rpad edge cases ###

query T
SELECT lpad('hello', 3)
----
hel

query T
SELECT lpad('hello', 0)
----
(empty)

query T
SELECT lpad('hello', -1)
----
(empty)

query T
SELECT lpad('', 5)
----


query T
SELECT lpad('hello', 10, '')
----
hello

query T
SELECT rpad('hello', 3)
----
hel

query T
SELECT rpad('hello', 0)
----
(empty)

query T
SELECT rpad('hello', -1)
----
(empty)

### replace function edge cases ###

query T
SELECT replace('hello', '', 'x')
----
hello

query T
SELECT replace('', 'a', 'b')
----
(empty)

query T
SELECT replace('aaa', 'a', '')
----
(empty)

query T
SELECT replace('hello', 'x', 'y')
----
hello

### split_part edge cases ###

query T
SELECT split_part('a,b,c', ',', 1)
----
a

query T
SELECT split_part('a,b,c', ',', 0)
----
(empty)

query T
SELECT split_part('a,b,c', ',', -1)
----
c

query T
SELECT split_part('a,b,c', ',', 100)
----
(empty)

query T
SELECT split_part('', ',', 1)
----
(empty)

query T
SELECT split_part('a,b,c', '', 1)
----
a,b,c

query T
SELECT split_part('a,b,c', 'not found', 1)
----
a,b,c

### translate edge cases ###

query T
SELECT translate('hello', '', '')
----
hello

query T
SELECT translate('hello', 'helo', '')
----
(empty)

query T
SELECT translate('', 'abc', 'xyz')
----
(empty)

# ==========================================
# Regex edge cases
# ==========================================

### regexp_match edge cases ###

query T
SELECT regexp_match('hello', '.*')
----
{hello}

query T
SELECT regexp_match('hello', '')
----
{""}

query T
SELECT regexp_match('', '.*')
----
{""}

query T
SELECT regexp_match('', '.+')
----
NULL

query T
SELECT regexp_match('hello', 'nomatch')
----
NULL

query T
SELECT regexp_match(NULL, 'pattern')
----
NULL

query T
SELECT regexp_match('text', NULL)
----
NULL

# Regex with groups
query T
SELECT regexp_match('hello world', '(\w+) (\w+)')
----
{hello,world}

# Empty capture group
query T
SELECT regexp_match('hello', '()')
----
{""}

### regexp_replace edge cases ###

query T
SELECT regexp_replace('hello', '.*', 'replaced')
----
replaced

query T
SELECT regexp_replace('hello', '', 'x')
----
xhxexlxlxox

query T
SELECT regexp_replace('', 'pattern', 'replacement')
----
(empty)

query T
SELECT regexp_replace('hello', 'nomatch', 'replaced')
----
hello

### ~ operator edge cases ###

query B
SELECT 'hello' ~ '.*'
----
true

query B
SELECT 'hello' ~ ''
----
true

query B
SELECT '' ~ '.*'
----
true

query B
SELECT '' ~ '.+'
----
false

query B
SELECT 'hello' ~ NULL
----
NULL

query B
SELECT NULL ~ 'pattern'
----
NULL

# ==========================================
# Subquery edge cases
# ==========================================

### Scalar subquery edge cases ###

query I
SELECT (SELECT 1)
----
1

query I
SELECT (SELECT 1 WHERE false)
----
NULL

# Multiple columns in scalar context should error
query error more than one column returned
SELECT (SELECT 1, 2)

# Multiple rows in scalar context should error
statement ok
CREATE TABLE scalar_test (x int)

statement ok
INSERT INTO scalar_test VALUES (1), (2)

query error more than one row returned
SELECT (SELECT x FROM scalar_test)

statement ok
DROP TABLE scalar_test

### EXISTS edge cases ###

query B
SELECT EXISTS (SELECT 1)
----
true

query B
SELECT EXISTS (SELECT 1 WHERE false)
----
false

query B
SELECT EXISTS (SELECT NULL)
----
true

query B
SELECT NOT EXISTS (SELECT 1 WHERE false)
----
true

### IN subquery edge cases ###

query B
SELECT 1 IN (SELECT 1)
----
true

query B
SELECT 1 IN (SELECT 1 WHERE false)
----
false

query B
SELECT 1 IN (SELECT NULL::int)
----
NULL

query B
SELECT NULL IN (SELECT 1)
----
NULL

### ANY/ALL subquery edge cases ###

query B
SELECT 1 = ANY (SELECT 1)
----
true

query B
SELECT 1 = ANY (SELECT 1 WHERE false)
----
false

query B
SELECT 1 = ALL (SELECT 1)
----
true

query B
SELECT 1 = ALL (SELECT 1 WHERE false)
----
true

# ==========================================
# Type coercion edge cases
# ==========================================

### Integer boundary coercion ###

query I
SELECT '2147483647'::int4
----
2147483647

query error out of range
SELECT '2147483648'::int4

query I
SELECT '-2147483648'::int4
----
-2147483648

query error out of range
SELECT '-2147483649'::int4

query I
SELECT '32767'::int2
----
32767

query error out of range
SELECT '32768'::int2

query I
SELECT '9223372036854775807'::int8
----
9223372036854775807

query error out of range
SELECT '9223372036854775808'::int8

### Float special value coercion ###

query R
SELECT 'NaN'::float
----
NaN

query R
SELECT 'Infinity'::float
----
inf

query R
SELECT '-Infinity'::float
----
-inf

query R
SELECT 'inf'::float
----
inf

query R
SELECT '-inf'::float
----
-inf

### Boolean coercion ###

query B
SELECT 'true'::bool
----
true

query B
SELECT 'false'::bool
----
false

query B
SELECT 't'::bool
----
true

query B
SELECT 'f'::bool
----
false

query B
SELECT 'yes'::bool
----
true

query B
SELECT 'no'::bool
----
false

query B
SELECT '1'::bool
----
true

query B
SELECT '0'::bool
----
false

query error invalid input syntax for type boolean
SELECT 'invalid'::bool

# ==========================================
# NULL handling edge cases
# ==========================================

### COALESCE edge cases ###

query I
SELECT COALESCE(NULL, NULL, NULL)
----
NULL

query I
SELECT COALESCE(1, NULL, 2)
----
1

query I
SELECT COALESCE(NULL, 1, 2)
----
1

query I
SELECT COALESCE(NULL, NULL, 3)
----
3

### NULLIF edge cases ###

query I
SELECT NULLIF(1, 1)
----
NULL

query I
SELECT NULLIF(1, 2)
----
1

query I
SELECT NULLIF(NULL, 1)
----
NULL

query I
SELECT NULLIF(1, NULL)
----
1

query I
SELECT NULLIF(NULL, NULL)
----
NULL

### GREATEST/LEAST with NULLs ###

query I
SELECT GREATEST(1, 2, 3)
----
3

query I
SELECT GREATEST(1, NULL, 3)
----
3

query I
SELECT GREATEST(NULL, NULL, NULL)
----
NULL

query I
SELECT LEAST(1, 2, 3)
----
1

query I
SELECT LEAST(1, NULL, 3)
----
1

query I
SELECT LEAST(NULL, NULL, NULL)
----
NULL

# ==========================================
# Window function edge cases
# ==========================================

statement ok
CREATE TABLE window_test (x int, y int)

statement ok
INSERT INTO window_test VALUES (1, 10), (1, 20), (2, 30), (2, 40), (NULL, 50)

### Window functions with empty partitions ###

query II
SELECT x, SUM(y) OVER (PARTITION BY x) FROM window_test WHERE false
----

### ROW_NUMBER edge cases ###

query III rowsort
SELECT x, y, ROW_NUMBER() OVER (PARTITION BY x ORDER BY y) FROM window_test
----
1  10  1
1  20  2
2  30  1
2  40  2
NULL  50  1

### RANK/DENSE_RANK edge cases ###

query III rowsort
SELECT x, y, RANK() OVER (ORDER BY x) FROM window_test
----
1  10  2
1  20  2
2  30  4
2  40  4
NULL  50  1

query III rowsort
SELECT x, y, DENSE_RANK() OVER (ORDER BY x) FROM window_test
----
1  10  2
1  20  2
2  30  3
2  40  3
NULL  50  1

### LAG/LEAD edge cases ###

query II rowsort
SELECT x, LAG(x) OVER (ORDER BY y) FROM window_test
----
1  NULL
1  1
2  1
2  2
NULL  2

query II rowsort
SELECT x, LEAD(x) OVER (ORDER BY y) FROM window_test
----
1  1
1  2
2  2
2  NULL
NULL  NULL

query II rowsort
SELECT x, LAG(x, 0) OVER (ORDER BY y) FROM window_test
----
1  1
1  1
2  2
2  2
NULL  NULL

query II rowsort
SELECT x, LAG(x, 100, -1) OVER (ORDER BY y) FROM window_test
----
1  -1
1  -1
2  -1
2  -1
NULL  -1

### FIRST_VALUE/LAST_VALUE edge cases ###

query II rowsort
SELECT x, FIRST_VALUE(x) OVER (PARTITION BY x ORDER BY y) FROM window_test
----
1  1
1  1
2  2
2  2
NULL  NULL

### NTH_VALUE edge cases ###

query II rowsort
SELECT x, NTH_VALUE(y, 1) OVER (PARTITION BY x ORDER BY y) FROM window_test
----
1  10
1  10
2  30
2  30
NULL  50

query II rowsort
SELECT x, NTH_VALUE(y, 100) OVER (PARTITION BY x ORDER BY y) FROM window_test
----
1  NULL
1  NULL
2  NULL
2  NULL
NULL  NULL

statement ok
DROP TABLE window_test

# ==========================================
# CTE (Common Table Expression) edge cases
# ==========================================

### Simple CTE ###

query I
WITH t AS (SELECT 1 AS x) SELECT x FROM t
----
1

### CTE with no rows ###

query I
WITH t AS (SELECT 1 WHERE false) SELECT * FROM t
----

### CTE referenced multiple times ###

query II
WITH t AS (SELECT 1 AS x) SELECT a.x, b.x FROM t AS a, t AS b
----
1  1

### Nested CTEs ###

query I
WITH t1 AS (SELECT 1 AS x), t2 AS (SELECT x + 1 AS y FROM t1) SELECT y FROM t2
----
2

### CTE with NULL ###

query I
WITH t AS (SELECT NULL::int AS x) SELECT x FROM t
----
NULL

# ==========================================
# Date/Time edge cases
# ==========================================

### Timestamp boundary values ###

query T
SELECT '0001-01-01 00:00:00'::timestamp
----
0001-01-01 00:00:00

query T
SELECT '9999-12-31 23:59:59.999999'::timestamp
----
9999-12-31 23:59:59.999999

### Interval edge cases ###

query T
SELECT INTERVAL '0'
----
00:00:00

query T
SELECT INTERVAL '1 microsecond'
----
00:00:00.000001

query T
SELECT INTERVAL '-1 day'
----
-1 days

query T
SELECT INTERVAL '1 year 2 months 3 days 4 hours 5 minutes 6 seconds'
----
1 year 2 months 3 days 04:05:06

### Date arithmetic edge cases ###

query T
SELECT DATE '2000-01-01' + INTERVAL '1 day'
----
2000-01-02 00:00:00

query T
SELECT DATE '2000-01-01' - INTERVAL '1 day'
----
1999-12-31 00:00:00

query T
SELECT DATE '2000-03-01' - INTERVAL '1 month'
----
2000-02-01 00:00:00

# Leap year edge case
query T
SELECT DATE '2000-02-29' + INTERVAL '1 year'
----
2001-02-28 00:00:00

### extract edge cases ###

query R
SELECT extract(year from DATE '0001-01-01')
----
1

query R
SELECT extract(month from DATE '0001-01-01')
----
1

query R
SELECT extract(day from DATE '0001-01-01')
----
1

query R
SELECT extract(epoch from TIMESTAMP '1970-01-01 00:00:00')
----
0

query R
SELECT extract(epoch from TIMESTAMP '1970-01-01 00:00:01')
----
1

### date_trunc edge cases ###

query T
SELECT date_trunc('year', TIMESTAMP '2000-06-15 12:30:45')
----
2000-01-01 00:00:00

query T
SELECT date_trunc('month', TIMESTAMP '2000-06-15 12:30:45')
----
2000-06-01 00:00:00

query T
SELECT date_trunc('day', TIMESTAMP '2000-06-15 12:30:45')
----
2000-06-15 00:00:00

query T
SELECT date_trunc('hour', TIMESTAMP '2000-06-15 12:30:45')
----
2000-06-15 12:00:00

query T
SELECT date_trunc('minute', TIMESTAMP '2000-06-15 12:30:45')
----
2000-06-15 12:30:00

query T
SELECT date_trunc('second', TIMESTAMP '2000-06-15 12:30:45.123456')
----
2000-06-15 12:30:45

# ==========================================
# Aggregate edge cases
# ==========================================

statement ok
CREATE TABLE agg_test (x int, y text, z float)

statement ok
INSERT INTO agg_test VALUES (1, 'a', 1.5), (2, 'b', 2.5), (NULL, NULL, NULL), (3, 'c', 'NaN')

### COUNT edge cases ###

query I
SELECT COUNT(*) FROM agg_test
----
4

query I
SELECT COUNT(x) FROM agg_test
----
3

query I
SELECT COUNT(*) FROM agg_test WHERE false
----
0

query I
SELECT COUNT(x) FROM agg_test WHERE false
----
0

### SUM edge cases ###

query I
SELECT SUM(x) FROM agg_test
----
6

query I
SELECT SUM(x) FROM agg_test WHERE false
----
NULL

### AVG edge cases ###

query R
SELECT AVG(x) FROM agg_test
----
2

query R
SELECT AVG(x) FROM agg_test WHERE false
----
NULL

### STRING_AGG edge cases ###

query T
SELECT STRING_AGG(y, ',') FROM agg_test
----
a,b,c

query T
SELECT STRING_AGG(y, ',') FROM agg_test WHERE false
----
NULL

query T
SELECT STRING_AGG(y, '') FROM agg_test
----
abc

### BOOL_AND/BOOL_OR edge cases ###

query B
SELECT BOOL_AND(x > 0) FROM agg_test
----
true

query B
SELECT BOOL_OR(x > 100) FROM agg_test
----
false

query B
SELECT BOOL_AND(x > 0) FROM agg_test WHERE false
----
NULL

query B
SELECT BOOL_OR(x > 0) FROM agg_test WHERE false
----
NULL

statement ok
DROP TABLE agg_test

# ==========================================
# CASE expression edge cases
# ==========================================

query I
SELECT CASE WHEN true THEN 1 END
----
1

query I
SELECT CASE WHEN false THEN 1 END
----
NULL

query I
SELECT CASE WHEN NULL THEN 1 ELSE 2 END
----
2

query I
SELECT CASE WHEN true THEN NULL ELSE 1 END
----
NULL

query I
SELECT CASE NULL WHEN NULL THEN 1 ELSE 2 END
----
2

# Nested CASE
query I
SELECT CASE WHEN true THEN CASE WHEN true THEN 1 END END
----
1

