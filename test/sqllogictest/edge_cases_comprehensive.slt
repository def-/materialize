----
NULL

# ==========================================
# Lateral join edge cases
# ==========================================

statement ok
CREATE TABLE lateral_test (x int)

statement ok
INSERT INTO lateral_test VALUES (1), (2), (3)

query II rowsort
SELECT * FROM lateral_test, LATERAL (SELECT x + 1 AS y) AS sub
----
1  2
2  3
3  4

query II rowsort
SELECT * FROM lateral_test, LATERAL (SELECT x WHERE x > 2) AS sub(y)
----
3  3

statement ok
DROP TABLE lateral_test
