# DISTINCT edge cases
# ==========================================

statement ok
CREATE TABLE distinct_test (x int)

statement ok
INSERT INTO distinct_test VALUES (1), (1), (2), (NULL), (NULL)

query I rowsort
SELECT DISTINCT x FROM distinct_test
----
NULL
1
2

query I
SELECT COUNT(DISTINCT x) FROM distinct_test
----
2

query I rowsort
SELECT DISTINCT x FROM distinct_test WHERE false
----

statement ok
DROP TABLE distinct_test

# ==========================================
# ORDER BY edge cases
# ==========================================

statement ok
CREATE TABLE order_test (x int, y text)

statement ok
INSERT INTO order_test VALUES (1, 'c'), (2, 'b'), (NULL, 'a'), (3, NULL)

query IT
SELECT * FROM order_test ORDER BY x
----
NULL  a
1  c
2  b
3  NULL

query IT
SELECT * FROM order_test ORDER BY x NULLS FIRST
----
NULL  a
1  c
2  b
3  NULL

query IT
SELECT * FROM order_test ORDER BY x NULLS LAST
----
1  c
2  b
3  NULL
NULL  a

query IT
SELECT * FROM order_test ORDER BY x DESC
----
3  NULL
2  b
1  c
NULL  a

query IT
SELECT * FROM order_test ORDER BY x DESC NULLS FIRST
----
NULL  a
3  NULL
2  b
1  c

query IT
SELECT * FROM order_test ORDER BY x DESC NULLS LAST
----
3  NULL
2  b
1  c
NULL  a

statement ok
DROP TABLE order_test

