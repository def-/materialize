select count(distinct column1) from (values (1)) _;
----
1

query I rowsort
select count(distinct column1) from (values (1), (2), (1), (4)) _;
----
3

query I rowsort
select sum(distinct column1) from (values (1), (2), (1), (4)) _;
----
7

