    (1, 'A', 10, 1.5, 10.5),
    (2, 'A', 20, 2.5, 20.5),
    (3, 'A', NULL, NULL, NULL),
    (4, 'B', 100, 100.5, 100.5),
    (5, 'B', 200, 200.5, 200.5),
    (6, 'C', NULL, NULL, NULL),
    (7, 'C', NULL, NULL, NULL)

