### String aggregate edge cases ###

query T
SELECT string_agg(grp, ',') FROM agg_test WHERE grp = 'A' GROUP BY grp
----
A,A,A

query T
SELECT string_agg(grp, ',') FROM agg_test WHERE false
----
NULL

query T
SELECT string_agg(grp, NULL) FROM agg_test WHERE grp = 'A' GROUP BY grp
----
NULL

query T
SELECT string_agg(NULL::text, ',') FROM agg_test WHERE grp = 'A'
----
NULL

query T
SELECT string_agg(grp, '') FROM agg_test WHERE grp = 'A' GROUP BY grp
----
AAA

