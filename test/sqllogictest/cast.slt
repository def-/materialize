query R
SELECT 1.4::int
----
1

query R
SELECT 1.5::int
----
2

query R
SELECT 1.4::real::int
----
1

query R
SELECT 1.5::real::int
----
2

query R
SELECT 1.4::float::int
----
1

query R
SELECT 1.5::float::int
----
2

query R
SELECT 1.4::bigint
----
1

query R
SELECT 1.5::bigint
----
2

query R
SELECT 1.4::real::bigint
----
1

query R
SELECT 1.5::real::bigint
----
2

query R
SELECT 1.4::float::bigint
----
1

query R
SELECT 1.5::float::bigint
----
