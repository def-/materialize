DROP CLUSTER multiprocess;

# ==========================================
# Additional edge case tests for potential panics/internal errors
# ==========================================

### Basic regex matching edge cases ###

query B
SELECT '' ~ ''
----
true

query B
SELECT 'abc' ~ ''
----
true

query B
SELECT '' ~ 'abc'
----
false

query B
SELECT '' ~ '^$'
----
true

query B
SELECT NULL ~ 'abc'
----
NULL

query B
SELECT 'abc' ~ NULL
----
NULL

query B
SELECT NULL ~ NULL
----
NULL

### Case insensitive matching edge cases ###

query B
SELECT 'ABC' ~* 'abc'
----
true

query B
SELECT 'abc' ~* 'ABC'
----
true

query B
SELECT 'AbC' ~* '^abc$'
----
true

query B
SELECT '' ~* ''
----
true

### Negated regex matching edge cases ###

query B
SELECT 'abc' !~ 'xyz'
----
true

query B
SELECT 'abc' !~ 'abc'
----
false

query B
SELECT '' !~ ''
----
false

query B
SELECT 'ABC' !~* 'abc'
----
false

query B
SELECT 'ABC' !~* 'xyz'
----
true

### Special regex characters edge cases ###

query B
SELECT 'a.b' ~ 'a\.b'
----
true

query B
SELECT 'a.b' ~ 'a.b'
----
true

query B
SELECT 'axb' ~ 'a.b'
----
true

query B
SELECT 'a*b' ~ 'a\*b'
----
true

query B
SELECT 'a+b' ~ 'a\+b'
----
true

query B
SELECT 'a?b' ~ 'a\?b'
----
true

query B
SELECT '[abc]' ~ '\[abc\]'
----
true

query B
SELECT '(abc)' ~ '\(abc\)'
----
true

query B
SELECT 'a{3}' ~ 'a\{3\}'
----
true

query B
SELECT 'a|b' ~ 'a\|b'
----
true

query B
SELECT '^abc$' ~ '\^abc\$'
----
true

### Anchor edge cases ###

query B
SELECT 'abc' ~ '^abc'
----
true

query B
SELECT 'abc' ~ 'abc$'
----
true

query B
SELECT 'abc' ~ '^abc$'
----
true

query B
SELECT 'xabc' ~ '^abc'
----
false

query B
SELECT 'abcx' ~ 'abc$'
----
false

query B
SELECT E'abc\ndef' ~ '^def'
----
false

query B
SELECT E'abc\ndef' ~ '(?m)^def'
----
true

### Character class edge cases ###

query B
SELECT 'a' ~ '[a-z]'
----
true

query B
SELECT 'Z' ~ '[a-z]'
----
false

query B
SELECT '5' ~ '[0-9]'
----
true

query B
SELECT '-' ~ '[-]'
----
true

query B
SELECT ']' ~ '[\]]'
----
true

query B
SELECT '[' ~ '[\[]'
----
true

query B
SELECT '^' ~ '[\^]'
----
true

query B
SELECT 'a' ~ '[^a]'
----
false

query B
SELECT 'b' ~ '[^a]'
----
true

### Quantifier edge cases ###

query B
SELECT '' ~ 'a*'
----
true

query B
SELECT 'aaa' ~ 'a*'
----
true

query B
SELECT '' ~ 'a+'
----
false

query B
SELECT 'a' ~ 'a+'
----
true

query B
SELECT 'aaa' ~ 'a+'
----
true

query B
SELECT '' ~ 'a?'
----
true

query B
SELECT 'a' ~ 'a?'
----
true

query B
SELECT 'aa' ~ '^a?$'
----
false

query B
SELECT 'aaa' ~ 'a{3}'
----
true

query B
SELECT 'aa' ~ 'a{3}'
----
false

query B
SELECT 'aaaa' ~ 'a{3}'
----
true

query B
SELECT 'aa' ~ 'a{2,4}'
----
true

query B
SELECT 'aaaaa' ~ '^a{2,4}$'
----
false

query B
SELECT 'aa' ~ 'a{2,}'
----
true

query B
SELECT 'aaaaaaa' ~ 'a{2,}'
----
true

### Alternation edge cases ###

query B
SELECT 'a' ~ 'a|b'
----
true

query B
SELECT 'b' ~ 'a|b'
----
true

query B
SELECT 'c' ~ 'a|b'
----
false

query B
SELECT '' ~ '|'
----
true

query B
SELECT 'a' ~ '|a'
----
true

query B
SELECT 'abc' ~ 'abc|def|ghi'
----
true

### Grouping edge cases ###

query B
SELECT 'ab' ~ '(ab)'
----
true

query B
SELECT 'abab' ~ '(ab)+'
----
true

query B
SELECT 'abab' ~ '(ab){2}'
----
true

query B
SELECT 'abab' ~ '^(ab){2}$'
----
true

query B
SELECT 'ab' ~ '(?:ab)'
----
true

### Backreference edge cases ###

query T
SELECT regexp_replace('abab', '(ab)\1', 'X')
----
X

query T
SELECT regexp_replace('abcd', '(ab)\1', 'X')
----
abcd

### regexp_replace edge cases ###

query T
SELECT regexp_replace('hello', 'l', 'L')
----
heLlo

query T
SELECT regexp_replace('hello', 'l', 'L', 'g')
----
heLLo

query T
