----
heXlo

query T
SELECT regexp_replace('hello', 'L', 'X', 'gi')
----
heXXo

query T
SELECT regexp_replace('', 'a', 'b')
----
(empty)

query T
SELECT regexp_replace('abc', '', 'X')
----
Xabc

query T
SELECT regexp_replace('abc', '', 'X', 'g')
----
XaXbXcX

query T
SELECT regexp_replace(NULL, 'a', 'b')
----
NULL

query T
SELECT regexp_replace('abc', NULL, 'b')
----
NULL

query T
SELECT regexp_replace('abc', 'a', NULL)
----
NULL

query T
SELECT regexp_replace('abc', 'x', 'y')
----
abc

query T
SELECT regexp_replace('abc123def456', '[0-9]+', '#', 'g')
----
abc#def#

query T
SELECT regexp_replace('hello world', '(\w+) (\w+)', '\2 \1')
----
world hello

query T
SELECT regexp_replace('aaa', 'a', 'bb', 'g')
----
bbbbbb

